{% comment %} eSIM Usage Lookup — page.my-esim-usage.liquid {% endcomment %}
{% comment %}
  Place this file in your Shopify theme at: templates/page.my-esim-usage.liquid
  Then create a Shopify page with handle "my-esim-usage" and template "page.my-esim-usage".
  Update the BACKEND constant below with your Railway deployment URL.
{% endcomment %}

<style>
  #esim-usage-app {
    max-width: 640px;
    margin: 2rem auto;
    font-family: inherit;
    padding: 0 1rem;
  }
  #esim-usage-app h2 {
    margin-bottom: 1.5rem;
  }
  #esim-search-form {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  #esim-query {
    flex: 1;
    padding: 0.6rem 0.8rem;
    font-size: 1rem;
    border: 1px solid #ccc;
    border-radius: 4px;
  }
  #esim-search-form button {
    padding: 0.6rem 1.2rem;
    font-size: 1rem;
    cursor: pointer;
    background: #000;
    color: #fff;
    border: none;
    border-radius: 4px;
  }
  #esim-search-form button:disabled {
    opacity: 0.6;
    cursor: default;
  }
  .esim-card {
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 1.25rem;
    margin-bottom: 1rem;
  }
  .esim-card h3 {
    margin: 0 0 0.75rem;
    font-size: 1rem;
  }
  .esim-row {
    display: flex;
    justify-content: space-between;
    padding: 0.3rem 0;
    font-size: 0.9rem;
    border-bottom: 1px solid #f0f0f0;
  }
  .esim-row:last-child {
    border-bottom: none;
  }
  .esim-row .label {
    color: #666;
  }
  .esim-progress-bar {
    margin: 0.75rem 0;
  }
  .esim-progress-bar .track {
    background: #eee;
    border-radius: 4px;
    height: 8px;
    overflow: hidden;
  }
  .esim-progress-bar .fill {
    background: #000;
    height: 100%;
    border-radius: 4px;
    transition: width 0.3s;
  }
  .esim-progress-bar .label {
    font-size: 0.8rem;
    color: #555;
    margin-top: 0.25rem;
  }
  .esim-spinner {
    text-align: center;
    padding: 2rem 0;
    color: #888;
  }
  .esim-error {
    color: #c00;
    padding: 1rem 0;
  }
  .esim-not-found {
    color: #555;
    padding: 1rem 0;
  }
</style>

<div id="esim-usage-app">
  <h2>{{ page.title }}</h2>

  <form id="esim-search-form">
    <input
      id="esim-query"
      type="text"
      placeholder="ICCID, order number, or email address"
      autocomplete="off"
      autocorrect="off"
      spellcheck="false"
    />
    <button type="submit" id="esim-submit">Search</button>
  </form>

  <div id="esim-results"></div>
</div>

<script>
  (function () {
    // ── Config — update this URL after each Railway deployment ──────────────
    var BACKEND = 'https://YOUR_RAILWAY_URL';
    // ─────────────────────────────────────────────────────────────────────────

    var form = document.getElementById('esim-search-form');
    var input = document.getElementById('esim-query');
    var results = document.getElementById('esim-results');
    var submitBtn = document.getElementById('esim-submit');

    // Auto-populate from ?iccid= URL param and auto-submit
    var params = new URLSearchParams(window.location.search);
    var iccidParam = params.get('iccid');
    if (iccidParam) {
      input.value = iccidParam;
      // Auto-submit once DOM is ready
      setTimeout(function () { doSearch(iccidParam); }, 0);
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var q = input.value.trim();
      if (q) doSearch(q);
    });

    function doSearch(q) {
      showSpinner();
      submitBtn.disabled = true;

      fetch(BACKEND + '/api/esim/usage?q=' + encodeURIComponent(q))
        .then(function (res) { return res.json().then(function (body) { return { status: res.status, body: body }; }); })
        .then(function (r) {
          submitBtn.disabled = false;
          if (r.status === 404) {
            showNotFound();
            return;
          }
          if (r.status !== 200) {
            showError('Unexpected error (' + r.status + '). Please try again.');
            return;
          }
          var body = r.body;
          // Multi-result (email search)
          if (body.results && Array.isArray(body.results)) {
            if (body.results.length === 0) { showNotFound(); return; }
            results.innerHTML = body.results.map(renderCard).join('');
          } else {
            results.innerHTML = renderCard(body);
          }
        })
        .catch(function (err) {
          submitBtn.disabled = false;
          showError('Could not reach the server. Please check your connection.');
        });
    }

    function renderCard(data) {
      var html = '<div class="esim-card">';
      html += '<h3>Order ' + esc(data.orderNum || '—') + '</h3>';
      html += row('ICCID', esc(data.iccid || '—'));
      html += row('Provider', esc(data.provider || '—'));

      if (data.provider === 'firoam') {
        html += renderFiRoamCard(data);
      } else if (data.provider === 'tgt') {
        html += renderTgtCard(data);
      }

      html += '</div>';
      return html;
    }

    function renderFiRoamCard(data) {
      var html = '';
      if (data.region) html += row('Region', esc(data.region));
      if (data.packageName) html += row('Package', esc(data.packageName));

      if (data.usage) {
        var u = data.usage;
        var pct = Math.min(100, Math.max(0, u.usagePercent || 0));
        var usedMb = u.usedMb != null ? u.usedMb : 0;
        var totalMb = u.totalMb != null ? u.totalMb : 0;
        html += '<div class="esim-progress-bar">';
        html += '<div class="track"><div class="fill" style="width:' + pct + '%"></div></div>';
        html += '<div class="label">' + formatMb(usedMb) + ' used of ' + formatMb(totalMb) + ' (' + Math.round(pct) + '%)</div>';
        html += '</div>';
      }

      if (data.validity) {
        var v = data.validity;
        if (v.beginDate) html += row('Active from', esc(v.beginDate));
        if (v.endDate) html += row('Expires', esc(v.endDate));
      }

      return html;
    }

    function renderTgtCard(data) {
      var html = '';
      if (data.vendorOrderNo) html += row('Vendor Order', esc(data.vendorOrderNo));
      if (data.usage) {
        var u = data.usage;
        if (u.dataTotal != null) html += row('Total data', esc(String(u.dataTotal)));
        if (u.dataUsage != null) html += row('Used', esc(String(u.dataUsage)));
        if (u.dataResidual != null) html += row('Remaining', esc(String(u.dataResidual)));
      }
      return html;
    }

    function row(label, value) {
      return '<div class="esim-row"><span class="label">' + label + '</span><span>' + value + '</span></div>';
    }

    function formatMb(mb) {
      if (mb >= 1024) return (mb / 1024).toFixed(1) + ' GB';
      return mb + ' MB';
    }

    function esc(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function showSpinner() {
      results.innerHTML = '<div class="esim-spinner">Loading…</div>';
    }

    function showNotFound() {
      results.innerHTML = '<div class="esim-not-found">We couldn\'t find any eSIM for that search.</div>';
    }

    function showError(msg) {
      results.innerHTML = '<div class="esim-error">' + esc(msg) + '</div>';
    }
  })();
</script>
