                  {% else %}
                    <div class="ai-tabbed-grid-product-image-placeholder-{{ ai_gen_id }}">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
                <h3 class="ai-tabbed-grid-product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
              </a>
              <p class="ai-tabbed-grid-product-price-{{ ai_gen_id }}">{{ product.price | money }}</p>
              <button
                class="ai-tabbed-grid-product-button-{{ ai_gen_id }}"
                data-product-handle="{{ product.handle }}"
              >
                {{ block.settings.button_text }}
              </button>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.global_collection != blank %}
