                  {% endif %}
                </div>
                <h3 class="ai-tabbed-grid-product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
              </a>
              <p class="ai-tabbed-grid-product-price-{{ ai_gen_id }}">{{ product.price | money }}</p>
              <button
                class="ai-tabbed-grid-product-button-{{ ai_gen_id }}"
                data-product-handle="{{ product.handle }}"
              >
                {{ block.settings.button_text }}
              </button>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.middle_east_collection != blank %}
      <div class="ai-tabbed-grid-content-{{ ai_gen_id }}" data-content="middle-east">
        <div class="ai-tabbed-grid-products-{{ ai_gen_id }}">
          {% for product in block.settings.middle_east_collection.products %}
            <div class="ai-tabbed-grid-product-{{ ai_gen_id }}">
              <a href="{{ product.url }}" class="ai-tabbed-grid-product-link-{{ ai_gen_id }}">
                <div class="ai-tabbed-grid-product-image-wrapper-{{ ai_gen_id }}">
                  {% if product.featured_image %}
                    <img
                      src="{{ product.featured_image | image_url: width: 400 }}"
                      alt="{{ product.featured_image.alt | escape }}"
                      class="ai-tabbed-grid-product-image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="400"
                      height="400"
                    >
                  {% else %}
                    <div class="ai-tabbed-grid-product-image-placeholder-{{ ai_gen_id }}">
                      {{ 'product-1' | placeholder_svg_tag }}
                    </div>
                  {% endif %}
                </div>
                <h3 class="ai-tabbed-grid-product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
              </a>
              <p class="ai-tabbed-grid-product-price-{{ ai_gen_id }}">{{ product.price | money }}</p>
              <button
                class="ai-tabbed-grid-product-button-{{ ai_gen_id }}"
                data-product-handle="{{ product.handle }}"
              >
                {{ block.settings.button_text }}
              </button>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>

  <div class="ai-tabbed-grid-modal-{{ ai_gen_id }}">
    <div class="ai-tabbed-grid-modal-content-{{ ai_gen_id }}">
      <button class="ai-tabbed-grid-modal-close-{{ ai_gen_id }}" aria-label="Close modal">&times;</button>
      <div class="ai-tabbed-grid-modal-body-{{ ai_gen_id }}">
        <div class="ai-tabbed-grid-modal-image-container-{{ ai_gen_id }}">
          <img src="" alt="" class="ai-tabbed-grid-modal-image-{{ ai_gen_id }}">
        </div>
        <div class="ai-tabbed-grid-modal-info-{{ ai_gen_id }}">
          <h2 class="ai-tabbed-grid-modal-title-{{ ai_gen_id }}"></h2>
          <div class="ai-tabbed-grid-modal-price-{{ ai_gen_id }}"></div>
          <div class="ai-tabbed-grid-modal-description-{{ ai_gen_id }}"></div>
          <div class="ai-tabbed-grid-modal-variants-{{ ai_gen_id }}"></div>
          <div class="ai-tabbed-grid-modal-quantity-{{ ai_gen_id }}">
            <label class="ai-tabbed-grid-modal-quantity-label-{{ ai_gen_id }}">Quantity:</label>
            <input
              type="number"
              class="ai-tabbed-grid-modal-quantity-input-{{ ai_gen_id }}"
              value="1"
              min="1"
            >
          </div>
          <div class="ai-tabbed-grid-modal-actions-{{ ai_gen_id }}">
            <button class="ai-tabbed-grid-modal-add-to-cart-{{ ai_gen_id }}">Add to Cart</button>
            <button class="ai-tabbed-grid-modal-buy-now-{{ ai_gen_id }}">Buy Now</button>
          </div>
