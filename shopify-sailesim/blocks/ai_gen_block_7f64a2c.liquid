<script>
  (function() {
    class RegionalEsimGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.tabs = this.querySelectorAll('.ai-tabbed-grid-tab-{{ ai_gen_id }}');
        this.contents = this.querySelectorAll('.ai-tabbed-grid-content-{{ ai_gen_id }}');
        this.productButtons = this.querySelectorAll('.ai-tabbed-grid-product-button-{{ ai_gen_id }}');
        this.modal = this.querySelector('.ai-tabbed-grid-modal-{{ ai_gen_id }}');
        this.modalClose = this.querySelector('.ai-tabbed-grid-modal-close-{{ ai_gen_id }}');
        this.currentProduct = null;
      }

      connectedCallback() {
        this.setupTabs();
        this.setupProductButtons();
        this.setupModal();
      }

      setupTabs() {
        this.tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            const tabName = tab.getAttribute('data-tab');
            
            this.tabs.forEach(t => t.classList.remove('active'));
            this.contents.forEach(c => c.classList.remove('active'));
            
            tab.classList.add('active');
            const content = this.querySelector(`[data-content="${tabName}"]`);
            if (content) {
              content.classList.add('active');
            }
          });
        });
      }

      setupProductButtons() {
        this.productButtons.forEach(button => {
          button.addEventListener('click', async () => {
            const handle = button.getAttribute('data-product-handle');
            await this.openProductModal(handle);
          });
        });
      }

      setupModal() {
        this.modalClose.addEventListener('click', () => {
          this.closeModal();
        });

        this.modal.addEventListener('click', (e) => {
          if (e.target === this.modal) {
            this.closeModal();
          }
        });

        const addToCartBtn = this.querySelector('.ai-tabbed-grid-modal-add-to-cart-{{ ai_gen_id }}');
        const buyNowBtn = this.querySelector('.ai-tabbed-grid-modal-buy-now-{{ ai_gen_id }}');

        addToCartBtn.addEventListener('click', () => {
          this.addToCart(false);
        });

        buyNowBtn.addEventListener('click', () => {
          this.addToCart(true);
        });
      }

      async openProductModal(handle) {
        try {
          const response = await fetch(`/products/${handle}.js`);
          const product = await response.json();
          this.currentProduct = product;
          this.renderProductModal(product);
          this.modal.classList.add('active');
          document.body.style.overflow = 'hidden';
        } catch (error) {
          console.error('Error loading product:', error);
        }
      }

      renderProductModal(product) {
        const modalImage = this.querySelector('.ai-tabbed-grid-modal-image-{{ ai_gen_id }}');
        const modalTitle = this.querySelector('.ai-tabbed-grid-modal-title-{{ ai_gen_id }}');
        const modalPrice = this.querySelector('.ai-tabbed-grid-modal-price-{{ ai_gen_id }}');
        const modalDescription = this.querySelector('.ai-tabbed-grid-modal-description-{{ ai_gen_id }}');
        const modalVariants = this.querySelector('.ai-tabbed-grid-modal-variants-{{ ai_gen_id }}');

        if (product.featured_image) {
          modalImage.src = product.featured_image;
          modalImage.alt = product.title;
        }

        modalTitle.textContent = product.title;
        modalPrice.textContent = this.formatMoney(product.price);
        modalDescription.innerHTML = product.description;

        modalVariants.innerHTML = '';
        if (product.variants && product.variants.length > 1) {
          product.options.forEach((option, index) => {
            const optionDiv = document.createElement('div');
            const label = document.createElement('label');
            label.className = 'ai-tabbed-grid-modal-variant-label-{{ ai_gen_id }}';
            label.textContent = option.name;
            
            const select = document.createElement('select');
            select.className = 'ai-tabbed-grid-modal-variant-select-{{ ai_gen_id }}';
            select.setAttribute('data-option-index', index);
            
            option.values.forEach(value => {
              const optionElement = document.createElement('option');
              optionElement.value = value;
              optionElement.textContent = value;
              select.appendChild(optionElement);
            });

            select.addEventListener('change', () => {
              this.updateSelectedVariant();
            });

            optionDiv.appendChild(label);
            optionDiv.appendChild(select);
            modalVariants.appendChild(optionDiv);
          });
        }
      }

      updateSelectedVariant() {
        const selects = this.querySelectorAll('.ai-tabbed-grid-modal-variant-select-{{ ai_gen_id }}');
        const selectedOptions = Array.from(selects).map(select => select.value);
        
        const variant = this.currentProduct.variants.find(v => {
          return selectedOptions.every((option, index) => {
            return v.options[index] === option;
          });
        });

        if (variant) {
          const modalPrice = this.querySelector('.ai-tabbed-grid-modal-price-{{ ai_gen_id }}');
          modalPrice.textContent = this.formatMoney(variant.price);
        }
      }

      async addToCart(buyNow) {
        const quantityInput = this.querySelector('.ai-tabbed-grid-modal-quantity-input-{{ ai_gen_id }}');
        const quantity = parseInt(quantityInput.value) || 1;
        
        const selects = this.querySelectorAll('.ai-tabbed-grid-modal-variant-select-{{ ai_gen_id }}');
        const selectedOptions = Array.from(selects).map(select => select.value);
        
        let variantId;
        if (this.currentProduct.variants.length === 1) {
          variantId = this.currentProduct.variants[0].id;
        } else {
          const variant = this.currentProduct.variants.find(v => {
            return selectedOptions.every((option, index) => {
              return v.options[index] === option;
            });
          });
          variantId = variant ? variant.id : this.currentProduct.variants[0].id;
        }

        const loadingDiv = this.querySelector('.ai-tabbed-grid-modal-loading-{{ ai_gen_id }}');
        loadingDiv.style.display = 'block';

        try {
          const formData = {
            items: [{
              id: variantId,
              quantity: quantity
            }]
          };

          const response = await fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(formData)
          });

          if (response.ok) {
            if (buyNow) {
              window.location.href = '/checkout';
            } else {
              this.closeModal();
              window.dispatchEvent(new Event('cart:updated'));
            }
          }
        } catch (error) {
          console.error('Error adding to cart:', error);
        } finally {
          loadingDiv.style.display = 'none';
        }
      }

      closeModal() {
        this.modal.classList.remove('active');
        document.body.style.overflow = '';
      }

      formatMoney(cents) {
        const amount = cents / 100;
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: '{{ cart.currency.iso_code }}'
        }).format(amount);
      }
    }

    customElements.define('regional-esim-grid-{{ ai_gen_id }}', RegionalEsimGrid{{ ai_gen_id }});
  })();
</script>

