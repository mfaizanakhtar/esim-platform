{% doc %}
  @prompt
    Create a Tabbed product grid block — exact duplicate of an existing block with these additional new features. All existing settings must be preserved exactly as listed below, plus the new features added.
    
    EXISTING SETTINGS TO PRESERVE:
    - Heading: "Shop by Region", 32px, center aligned, slide-up animation, 1s speed
    - Subheading: "Explore our regional collections", 16px, center aligned, slide-in-left animation, 1s speed
    - Max width: 1100px, section padding: 40px
    - Products per row desktop: 8 (max 12), mobile: 3 (max 6), grid gap: 12px
    - Tabs: Tab 1 "Asia" (collection: asia-1), Tab 2 "Europe", Tab 3 "Global", Tab 4 "Middle East", Tab 5 & 6 empty
    - Tab colors: text #121212, border #cccccc, hover bg #f4f4f4, hover border #121212, active bg #121212, active text #ffffff, active border #121212
    - Card: background #ffffff, border-radius 8px, price color #121212
    - Button: pill shape border-radius 999px, font-size 12px, font-weight 600, text #ffffff, background #121212, border #121212, hover text #121212, hover bg #ffffff, hover border #121212, padding 8px 24px, white-space: nowrap
    - Product images: 3:2 landscape aspect ratio, object-fit: cover, zero blank padding or whitespace, fills container edge to edge
    
    NEW FEATURES TO ADD:
    1. CLICKABLE PRODUCT — both the product image and product name must be clickable links that navigate to the product page
    2. BUTTON ACTION SELECTOR — expose a setting in the theme editor to choose button action: "Add to Cart" OR "Buy Now" (direct checkout). When "Buy Now" is selected, clicking the button takes customer directly to checkout with that product
    3. BUTTON TEXT — expose an editable text field so merchant can customize the button label (default: "Add to Cart")
    4. BUTTON CUSTOMIZATION — all button styles already editable (font size, weight, text color, background, border color, hover states)
    
    Block should be homepage-only, fully centered, modern and clean for a futuristic eSIM store
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-tabbed-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-tabbed-grid-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-tabbed-grid-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    text-align: {{ block.settings.heading_alignment }};
    margin: 0 0 10px;
    opacity: 0;
    transform: translateY(20px);
  }

  .ai-tabbed-grid-heading-{{ ai_gen_id }}.animate {
    animation: ai-slide-up-{{ ai_gen_id }} {{ block.settings.heading_animation_speed }}s ease-out forwards;
  }

  .ai-tabbed-grid-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    text-align: {{ block.settings.subheading_alignment }};
    margin: 0 0 30px;
    opacity: 0;
    transform: translateX(-20px);
  }

  .ai-tabbed-grid-subheading-{{ ai_gen_id }}.animate {
    animation: ai-slide-in-left-{{ ai_gen_id }} {{ block.settings.subheading_animation_speed }}s ease-out forwards;
  }

  @keyframes ai-slide-up-{{ ai_gen_id }} {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes ai-slide-in-left-{{ ai_gen_id }} {
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .ai-tabbed-grid-tabs-{{ ai_gen_id }} {
    display: flex;
    gap: 10px;
    margin-bottom: 30px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .ai-tabbed-grid-tab-{{ ai_gen_id }} {
    padding: 10px 20px;
    background: transparent;
    border: 1px solid {{ block.settings.tab_border_color }};
    color: {{ block.settings.tab_text_color }};
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 14px;
  }

  .ai-tabbed-grid-tab-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.tab_hover_bg }};
    border-color: {{ block.settings.tab_hover_border }};
  }

  .ai-tabbed-grid-tab-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.tab_active_bg }};
    color: {{ block.settings.tab_active_text }};
    border-color: {{ block.settings.tab_active_border }};
  }

  .ai-tabbed-grid-content-{{ ai_gen_id }} {
    display: none;
  }

  .ai-tabbed-grid-content-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-tabbed-grid-products-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-tabbed-grid-products-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_mobile }}, 1fr);
    }
  }

  .ai-tabbed-grid-product-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .ai-tabbed-grid-product-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 66.67%;
    overflow: hidden;
  }

  .ai-tabbed-grid-product-image-link-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .ai-tabbed-grid-product-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-tabbed-grid-product-info-{{ ai_gen_id }} {
    padding: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex-grow: 1;
  }

  .ai-tabbed-grid-product-title-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .ai-tabbed-grid-product-title-{{ ai_gen_id }} {
    font-size: 14px;
    margin: 0;
    font-weight: 500;
  }

  .ai-tabbed-grid-product-price-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.price_color }};
    font-weight: 600;
  }

  .ai-tabbed-grid-product-button-{{ ai_gen_id }} {
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    color: {{ block.settings.button_text_color }};
    background-color: {{ block.settings.button_bg }};
    border: 1px solid {{ block.settings.button_border }};
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
    text-align: center;
  }

  .ai-tabbed-grid-product-button-{{ ai_gen_id }}:hover {
    color: {{ block.settings.button_hover_text }};
    background-color: {{ block.settings.button_hover_bg }};
    border-color: {{ block.settings.button_hover_border }};
  }

  .ai-tabbed-grid-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: #666;
  }
{% endstyle %}

<tabbed-product-grid-{{ ai_gen_id }} class="ai-tabbed-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-tabbed-grid-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-tabbed-grid-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.subheading != blank %}
      <p class="ai-tabbed-grid-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
    {% endif %}

    <div class="ai-tabbed-grid-tabs-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign tab_label_key = 'tab_' | append: i | append: '_label'
          assign tab_collection_key = 'tab_' | append: i | append: '_collection'
          assign tab_label = block.settings[tab_label_key]
          assign tab_collection = block.settings[tab_collection_key]
        %}
        {% if tab_label != blank %}
          <button
            class="ai-tabbed-grid-tab-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            data-tab="{{ i }}"
          >
            {{ tab_label }}
          </button>
        {% endif %}
      {% endfor %}
    </div>

    {% for i in (1..6) %}
      {% liquid
        assign tab_label_key = 'tab_' | append: i | append: '_label'
        assign tab_collection_key = 'tab_' | append: i | append: '_collection'
        assign tab_label = block.settings[tab_label_key]
        assign tab_collection = block.settings[tab_collection_key]
      %}
      {% if tab_label != blank %}
        <div
          class="ai-tabbed-grid-content-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
          data-content="{{ i }}"
        >
          {% if tab_collection != blank and tab_collection.products.size > 0 %}
            <div class="ai-tabbed-grid-products-{{ ai_gen_id }}">
              {% for product in tab_collection.products %}
                <div class="ai-tabbed-grid-product-card-{{ ai_gen_id }}">
                  <div class="ai-tabbed-grid-product-image-wrapper-{{ ai_gen_id }}">
                    <a href="{{ product.url }}" class="ai-tabbed-grid-product-image-link-{{ ai_gen_id }}">
                      {% if product.featured_image %}
                        <img
                          src="{{ product.featured_image | image_url: width: 600 }}"
                          alt="{{ product.featured_image.alt | escape }}"
                          class="ai-tabbed-grid-product-image-{{ ai_gen_id }}"
                          loading="lazy"
                          width="600"
                          height="400"
                        >
                      {% else %}
                        <div class="ai-tabbed-grid-product-image-{{ ai_gen_id }}" style="background-color: #f4f4f4;"></div>
                      {% endif %}
                    </a>
                  </div>
                  <div class="ai-tabbed-grid-product-info-{{ ai_gen_id }}">
                    <a href="{{ product.url }}" class="ai-tabbed-grid-product-title-link-{{ ai_gen_id }}">
                      <h3 class="ai-tabbed-grid-product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                    </a>
                    <div class="ai-tabbed-grid-product-price-{{ ai_gen_id }}">
                      {{ product.price | money }}
                    </div>
                    <button
                      class="ai-tabbed-grid-product-button-{{ ai_gen_id }}"
                      data-product-id="{{ product.id }}"
                      data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                      data-action="{{ block.settings.button_action }}"
                    >
                      {{ block.settings.button_text }}
                    </button>
                  </div>
                </div>
              {% endfor %}
            </div>
          {% else %}
            <div class="ai-tabbed-grid-empty-{{ ai_gen_id }}">
              <p>No products found in this collection.</p>
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</tabbed-product-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class TabbedProductGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.tabs = this.querySelectorAll('.ai-tabbed-grid-tab-{{ ai_gen_id }}');
        this.contents = this.querySelectorAll('.ai-tabbed-grid-content-{{ ai_gen_id }}');
        this.heading = this.querySelector('.ai-tabbed-grid-heading-{{ ai_gen_id }}');
        this.subheading = this.querySelector('.ai-tabbed-grid-subheading-{{ ai_gen_id }}');
        
        this.setupTabs();
        this.setupButtons();
        this.setupAnimations();
      }

      setupTabs() {
        this.tabs.forEach((tab) => {
          tab.addEventListener('click', () => {
            const tabId = tab.getAttribute('data-tab');
            
            this.tabs.forEach((t) => t.classList.remove('active'));
            this.contents.forEach((c) => c.classList.remove('active'));
            
            tab.classList.add('active');
            const content = this.querySelector(`[data-content="${tabId}"]`);
            if (content) {
              content.classList.add('active');
            }
          });
        });
      }

      setupButtons() {
        const buttons = this.querySelectorAll('.ai-tabbed-grid-product-button-{{ ai_gen_id }}');
        
        buttons.forEach((button) => {
          button.addEventListener('click', (e) => {
            e.preventDefault();
            const variantId = button.getAttribute('data-variant-id');
            const action = button.getAttribute('data-action');
            
            if (!variantId) return;
            
            const formData = {
              items: [{
                id: variantId,
                quantity: 1
              }]
            };
            
            fetch('/cart/add.js', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
              },
              body: JSON.stringify(formData)
            })
            .then(response => response.json())
            .then(data => {
              if (action === 'buy_now') {
                window.location.href = '/checkout';
              } else {
                if (window.theme && window.theme.cart) {
                  window.theme.cart.refresh();
                } else {
                  fetch('/cart.js')
                    .then(response => response.json())
                    .then(cart => {
                      document.dispatchEvent(new CustomEvent('cart:refresh', { detail: cart }));
                    });
                }
              }
            })
            .catch((error) => {
              console.error('Error:', error);
            });
          });
        });
      }

      setupAnimations() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('animate');
            }
          });
        }, { threshold: 0.1 });

        if (this.heading) {
          observer.observe(this.heading);
        }
        if (this.subheading) {
          observer.observe(this.subheading);
        }
      }
    }

    customElements.define('tabbed-product-grid-{{ ai_gen_id }}', TabbedProductGrid{{ ai_gen_id }});
  })();
</script>

