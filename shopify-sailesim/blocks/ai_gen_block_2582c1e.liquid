<script>
  (function() {
    class TabbedProductGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.selectedOptions = {};
        this.currentProduct = null;
      }

      connectedCallback() {
        this.setupTabs();
        this.setupModal();
        this.setupChoosePlanButtons();
      }

      setupTabs() {
        const tabs = this.querySelectorAll('.ai-tabbed-tab-{{ ai_gen_id }}');
        const contents = this.querySelectorAll('.ai-tabbed-content-{{ ai_gen_id }}');

        tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            const tabId = tab.getAttribute('data-tab');
            
            tabs.forEach(t => t.classList.remove('active'));
            contents.forEach(c => c.classList.remove('active'));
            
            tab.classList.add('active');
            const content = this.querySelector(`[data-content="${tabId}"]`);
            if (content) content.classList.add('active');
          });
        });
      }

      setupModal() {
        const modal = this.querySelector('.ai-tabbed-modal-{{ ai_gen_id }}');
        const overlay = this.querySelector('.ai-tabbed-modal-overlay-{{ ai_gen_id }}');
        const closeBtn = this.querySelector('.ai-tabbed-modal-close-{{ ai_gen_id }}');

        closeBtn.addEventListener('click', () => this.closeModal());
        overlay.addEventListener('click', () => this.closeModal());

        const quantityBtns = this.querySelectorAll('.ai-tabbed-modal-quantity-btn-{{ ai_gen_id }}');
        const quantityInput = this.querySelector('#ai-modal-quantity-{{ ai_gen_id }}');

        quantityBtns.forEach(btn => {
          btn.addEventListener('click', () => {
            const action = btn.getAttribute('data-action');
            let value = parseInt(quantityInput.value);
            
            if (action === 'increase') {
              value++;
            } else if (action === 'decrease' && value > 1) {
              value--;
            }
            
            quantityInput.value = value;
          });
        });

        const addToCartBtn = this.querySelector('#ai-modal-add-to-cart-{{ ai_gen_id }}');
        addToCartBtn.addEventListener('click', () => this.addToCart());

        const buyNowBtn = this.querySelector('#ai-modal-buy-now-{{ ai_gen_id }}');
        buyNowBtn.addEventListener('click', () => this.buyNow());
      }

      setupChoosePlanButtons() {
        const buttons = this.querySelectorAll('.ai-tabbed-button-{{ ai_gen_id }}');
        
        buttons.forEach(button => {
          button.addEventListener('click', async () => {
            const productHandle = button.getAttribute('data-product-handle');
            await this.openModal(productHandle);
          });
        });
      }

      async openModal(productHandle) {
        try {
          const response = await fetch(`/products/${productHandle}.js`);
          const product = await response.json();
          
          this.currentProduct = product;
          this.selectedOptions = {};
          
          const modalImage = this.querySelector('#ai-modal-image-{{ ai_gen_id }}');
          const modalTitle = this.querySelector('#ai-modal-title-{{ ai_gen_id }}');
          const modalPrice = this.querySelector('#ai-modal-price-{{ ai_gen_id }}');
          const modalDescription = this.querySelector('#ai-modal-description-{{ ai_gen_id }}');
          const modalOptions = this.querySelector('#ai-modal-options-{{ ai_gen_id }}');
          
          if (product.featured_image) {
            modalImage.src = product.featured_image;
            modalImage.alt = product.title;
          }
          
          modalTitle.textContent = product.title;
          modalPrice.textContent = this.formatMoney(product.price);
          modalDescription.innerHTML = product.description || '';
          
          modalOptions.innerHTML = '';
          
          if (product.options && product.options.length > 0 && product.options[0] !== 'Title') {
            product.options.forEach((option, index) => {
              const optionDiv = document.createElement('div');
              optionDiv.className = 'ai-tabbed-modal-option-{{ ai_gen_id }}';
              
              const label = document.createElement('label');
              label.className = 'ai-tabbed-modal-option-label-{{ ai_gen_id }}';
              label.textContent = option;
              
              const buttonsDiv = document.createElement('div');
              buttonsDiv.className = 'ai-tabbed-modal-option-buttons-{{ ai_gen_id }}';
              
              const values = [...new Set(product.variants.map(v => v.options[index]))];
              
              values.forEach(value => {
                const button = document.createElement('button');
                button.className = 'ai-tabbed-modal-option-button-{{ ai_gen_id }}';
                button.textContent = value;
                button.setAttribute('data-option-index', index);
                button.setAttribute('data-option-value', value);
                
                button.addEventListener('click', () => {
                  const siblings = buttonsDiv.querySelectorAll('button');
                  siblings.forEach(s => s.classList.remove('selected'));
                  button.classList.add('selected');
                  
                  this.selectedOptions[index] = value;
                  this.updateVariant();
                });
                
                buttonsDiv.appendChild(button);
              });
              
              optionDiv.appendChild(label);
              optionDiv.appendChild(buttonsDiv);
              modalOptions.appendChild(optionDiv);
            });
          }
          
          const modal = this.querySelector('.ai-tabbed-modal-{{ ai_gen_id }}');
          const overlay = this.querySelector('.ai-tabbed-modal-overlay-{{ ai_gen_id }}');
          
          modal.classList.add('active');
          overlay.classList.add('active');
          document.body.style.overflow = 'hidden';
          
          this.initializeFirstOptions();
        } catch (error) {
          console.error('Error loading product:', error);
        }
      }

      initializeFirstOptions() {
        const optionButtons = this.querySelectorAll('.ai-tabbed-modal-option-button-{{ ai_gen_id }}');
        const clickedIndices = new Set();
        
        optionButtons.forEach(button => {
          const index = button.getAttribute('data-option-index');
          if (!clickedIndices.has(index)) {
            clickedIndices.add(index);
            button.click();
          }
        });
      }

      closeModal() {
        const modal = this.querySelector('.ai-tabbed-modal-{{ ai_gen_id }}');
        const overlay = this.querySelector('.ai-tabbed-modal-overlay-{{ ai_gen_id }}');
        
        modal.classList.remove('active');
        overlay.classList.remove('active');
        document.body.style.overflow = '';
        
        this.selectedOptions = {};
        this.currentProduct = null;
      }

      updateVariant() {
        const variant = this.getCurrentVariant();
        
        if (variant) {
          const modalPrice = this.querySelector('#ai-modal-price-{{ ai_gen_id }}');
          modalPrice.textContent = this.formatMoney(variant.price);
        }
        
        this.updateAvailability();
      }

      getCurrentVariant() {
        if (!this.currentProduct) return null;
        
        return this.currentProduct.variants.find(variant => {
          return variant.options.every((option, index) => {
            return !this.selectedOptions[index] || option === this.selectedOptions[index];
          });
        });
      }

      updateAvailability() {
        const optionButtons = this.querySelectorAll('.ai-tabbed-modal-option-button-{{ ai_gen_id }}');
        
        optionButtons.forEach(button => {
          const optionIndex = parseInt(button.getAttribute('data-option-index'));
          const optionValue = button.getAttribute('data-option-value');
          
          const isAvailable = this.isOptionAvailable(optionIndex, optionValue);
          
          if (isAvailable) {
            button.disabled = false;
          } else {
            button.disabled = true;
          }
        });
      }

      isOptionAvailable(optionIndex, value) {
        if (!this.currentProduct) return true;

        return this.currentProduct.variants.some(variant => {
          if (variant.options[optionIndex] !== value) {
            return false;
          }
          
          const matchesSelected = Object.keys(this.selectedOptions).every(index => {
            return parseInt(index) === optionIndex || variant.options[index] === this.selectedOptions[index];
          });
          
          return matchesSelected && variant.available;
        });
      }

      async addToCart() {
        const variant = this.getCurrentVariant();
        if (!variant) {
          alert('Please select all options');
          return;
        }

        const quantity = parseInt(this.querySelector('#ai-modal-quantity-{{ ai_gen_id }}').value);
        
        try {
          const response = await fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              id: variant.id,
              quantity: quantity
            })
          });
          
          if (response.ok) {
            this.closeModal();
            window.location.href = '/cart';
          } else {
            alert('Error adding to cart');
          }
        } catch (error) {
          console.error('Error:', error);
          alert('Error adding to cart');
        }
      }

      buyNow() {
        const variant = this.getCurrentVariant();
        if (!variant) {
          alert('Please select all options');
          return;
        }

        const quantity = parseInt(this.querySelector('#ai-modal-quantity-{{ ai_gen_id }}').value);
        window.location.href = `/cart/${variant.id}:${quantity}`;
      }

      formatMoney(cents) {
        const amount = cents / 100;
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: '{{ cart.currency.iso_code }}'
        }).format(amount);
      }
    }

    customElements.define('tabbed-product-grid-{{ ai_gen_id }}', TabbedProductGrid{{ ai_gen_id }});
  })();
</script>

