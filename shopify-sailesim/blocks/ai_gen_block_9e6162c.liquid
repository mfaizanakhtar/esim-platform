<script>
(function() {
  class RegionalEsimGrid{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.currentProduct = null;
      this.selectedOptions = {};
      this.selectedVariant = null;
      this.quantity = 1;
    }

    connectedCallback() {
      this.setupTabs();
      this.setupModal();
      this.setupChooseButtons();
    }

    setupTabs() {
      const tabs = this.querySelectorAll('.ai-regional-esim-tab-{{ ai_gen_id }}');
      const contents = this.querySelectorAll('.ai-regional-esim-tab-content-{{ ai_gen_id }}');

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const targetTab = tab.dataset.tab;

          tabs.forEach(t => t.classList.remove('active'));
          contents.forEach(c => c.classList.remove('active'));

          tab.classList.add('active');
          const targetContent = this.querySelector(`[data-content="${targetTab}"]`);
          if (targetContent) {
            targetContent.classList.add('active');
          }
        });
      });
    }

    setupModal() {
      const overlay = this.querySelector('.ai-regional-esim-modal-overlay-{{ ai_gen_id }}');
      const closeBtn = this.querySelector('.ai-regional-esim-modal-close-{{ ai_gen_id }}');
      const qtyMinus = this.querySelector('#qty-minus-{{ ai_gen_id }}');
      const qtyPlus = this.querySelector('#qty-plus-{{ ai_gen_id }}');
      const qtyInput = this.querySelector('#qty-input-{{ ai_gen_id }}');
      const addToCartBtn = this.querySelector('#add-to-cart-{{ ai_gen_id }}');
      const buyNowBtn = this.querySelector('#buy-now-{{ ai_gen_id }}');

      closeBtn.addEventListener('click', () => this.closeModal());
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) {
          this.closeModal();
        }
      });

      qtyMinus.addEventListener('click', () => {
        if (this.quantity > 1) {
          this.quantity--;
          qtyInput.value = this.quantity;
        }
      });

      qtyPlus.addEventListener('click', () => {
        this.quantity++;
        qtyInput.value = this.quantity;
      });

      qtyInput.addEventListener('change', (e) => {
        const val = parseInt(e.target.value);
        if (val >= 1) {
          this.quantity = val;
        } else {
          this.quantity = 1;
          qtyInput.value = 1;
        }
      });

      addToCartBtn.addEventListener('click', () => this.addToCart());
      buyNowBtn.addEventListener('click', () => this.buyNow());
    }

    setupChooseButtons() {
      const buttons = this.querySelectorAll('.ai-regional-esim-choose-btn-{{ ai_gen_id }}');
      buttons.forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const productHandle = btn.dataset.productHandle;
          this.loadProduct(productHandle);
        });
      });
    }

    async loadProduct(handle) {
      try {
        const response = await fetch(`/products/${handle}.js`);
        const product = await response.json();
        this.currentProduct = product;
        this.selectedOptions = {};
        
        if (product.options && product.options.length > 0) {
          product.options.forEach((option, index) => {
            if (option.values && option.values.length > 0) {
              this.selectedOptions[option.name] = option.values[0];
            }
          });
        }
        
        this.selectedVariant = product.variants && product.variants.length > 0 ? product.variants[0] : null;
        this.renderModal(product);
        this.openModal();
      } catch (error) {
        console.error('Error loading product:', error);
      }
    }

    renderModal(product) {
      const modalImage = this.querySelector('#modal-image-{{ ai_gen_id }}');
      const modalTitle = this.querySelector('#modal-title-{{ ai_gen_id }}');
      const modalPrice = this.querySelector('#modal-price-{{ ai_gen_id }}');
      const modalDescription = this.querySelector('#modal-description-{{ ai_gen_id }}');
      const modalVariants = this.querySelector('#modal-variants-{{ ai_gen_id }}');

      if (product.featured_image) {
        modalImage.src = product.featured_image;
        modalImage.alt = product.title;
      }

      modalTitle.textContent = product.title;
      modalPrice.textContent = this.formatMoney(product.price);

      if (modalDescription && product.description) {
        const tempDiv = document.createElement('div');
        tempDiv.innerHTML = product.description;
        modalDescription.textContent = tempDiv.textContent || tempDiv.innerText || '';
      }

      this.renderVariantSelectors(product, modalVariants);
    }

    renderVariantSelectors(product, container) {
      container.innerHTML = '';

      if (!product.options || product.options.length === 0) {
        return;
      }

      if (product.options.length === 1 && product.options[0].name === 'Title') {
        return;
      }

      product.options.forEach((option, index) => {
        if (!option.values || option.values.length === 0) {
          return;
        }

        const section = document.createElement('div');
        section.className = 'ai-regional-esim-variant-section-{{ ai_gen_id }}';

        const label = document.createElement('label');
        label.className = 'ai-regional-esim-variant-label-{{ ai_gen_id }}';
        label.textContent = option.name;
        section.appendChild(label);

        const optionsContainer = document.createElement('div');
        optionsContainer.className = 'ai-regional-esim-variant-options-{{ ai_gen_id }}';

        option.values.forEach(value => {
          const optionBtn = document.createElement('button');
          optionBtn.className = 'ai-regional-esim-variant-option-{{ ai_gen_id }}';
          optionBtn.textContent = value;
          optionBtn.dataset.optionName = option.name;
          optionBtn.dataset.optionValue = value;
          optionBtn.dataset.optionPosition = index;

          if (this.selectedOptions[option.name] === value) {
            optionBtn.classList.add('selected');
          }

          optionBtn.addEventListener('click', (e) => {
            e.preventDefault();
            this.selectOption(option.name, value, index, product);
          });

          optionsContainer.appendChild(optionBtn);
        });

        section.appendChild(optionsContainer);
        container.appendChild(section);
      });

      this.updateVariantAvailability(product);
      this.updateSelectedVariant(product);
    }

    selectOption(optionName, value, position, product) {
      this.selectedOptions[optionName] = value;

      const buttons = this.querySelectorAll(`.ai-regional-esim-variant-option-{{ ai_gen_id }}[data-option-name="${optionName}"]`);
      buttons.forEach(btn => {
        if (btn.dataset.optionValue === value) {
          btn.classList.add('selected');
        } else {
          btn.classList.remove('selected');
        }
      });

      this.updateSelectedVariant(product);
      this.updateVariantAvailability(product);
    }

    updateSelectedVariant(product) {
      if (!product.variants || product.variants.length === 0) {
        return;
      }

      const variant = product.variants.find(v => {
        if (!v.options || v.options.length === 0) {
          return false;
        }
        
        return product.options.every((option, idx) => {
          const selectedValue = this.selectedOptions[option.name];
          return v.options[idx] === selectedValue;
        });
      });

      if (variant) {
        this.selectedVariant = variant;
        const modalPrice = this.querySelector('#modal-price-{{ ai_gen_id }}');
        if (modalPrice) {
          modalPrice.textContent = this.formatMoney(variant.price);
        }
      }
    }

    updateVariantAvailability(product) {
      if (!product.variants || product.variants.length === 0) {
        return;
      }

      const allButtons = this.querySelectorAll('.ai-regional-esim-variant-option-{{ ai_gen_id }}');
      
      allButtons.forEach(btn => {
        const optionName = btn.dataset.optionName;
        const optionValue = btn.dataset.optionValue;
        const position = parseInt(btn.dataset.optionPosition);
        
        const testOptions = { ...this.selectedOptions };
        testOptions[optionName] = optionValue;
        
        const hasAvailableVariant = product.variants.some(v => {
          if (!v.options || v.options.length === 0) {
            return false;
          }
          
          const optionMatches = product.options.every((option, idx) => {
            const testValue = testOptions[option.name];
            return v.options[idx] === testValue;
          });
          
          return optionMatches && v.available;
        });

        if (!hasAvailableVariant) {
          btn.classList.add('disabled');
          btn.disabled = true;
        } else {
          btn.classList.remove('disabled');
          btn.disabled = false;
        }
      });
    }

    async addToCart() {
      if (!this.selectedVariant) {
        this.showError('Please select a variant');
        return;
      }

      if (!this.selectedVariant.available) {
        this.showError('This variant is not available');
        return;
      }

      const addToCartBtn = this.querySelector('#add-to-cart-{{ ai_gen_id }}');
      addToCartBtn.disabled = true;
      addToCartBtn.textContent = 'Adding...';

      try {
        const response = await fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            id: this.selectedVariant.id,
            quantity: this.quantity
          })
        });

        if (response.ok) {
          addToCartBtn.textContent = 'Added!';
          setTimeout(() => {
            this.closeModal();
            addToCartBtn.textContent = 'Add to Cart';
            addToCartBtn.disabled = false;
            window.dispatchEvent(new Event('cart:refresh'));
          }, 1000);
        } else {
          throw new Error('Failed to add to cart');
        }
      } catch (error) {
        this.showError('Failed to add to cart. Please try again.');
        addToCartBtn.textContent = 'Add to Cart';
        addToCartBtn.disabled = false;
      }
    }

    async buyNow() {
      if (!this.selectedVariant) {
        this.showError('Please select a variant');
        return;
      }

      if (!this.selectedVariant.available) {
        this.showError('This variant is not available');
        return;
      }

      const buyNowBtn = this.querySelector('#buy-now-{{ ai_gen_id }}');
      buyNowBtn.disabled = true;
      buyNowBtn.textContent = 'Processing...';

      try {
        const response = await fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            id: this.selectedVariant.id,
            quantity: this.quantity
          })
        });

        if (response.ok) {
          window.location.href = '/checkout';
        } else {
          throw new Error('Failed to add to cart');
        }
      } catch (error) {
        this.showError('Failed to process. Please try again.');
        buyNowBtn.textContent = 'Buy Now';
        buyNowBtn.disabled = false;
      }
    }

    showError(message) {
      const errorEl = this.querySelector('#modal-error-{{ ai_gen_id }}');
      if (errorEl) {
        errorEl.textContent = message;
        errorEl.style.display = 'block';
        setTimeout(() => {
          errorEl.style.display = 'none';
        }, 3000);
      }
    }

    openModal() {
      const overlay = this.querySelector('.ai-regional-esim-modal-overlay-{{ ai_gen_id }}');
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    closeModal() {
      const overlay = this.querySelector('.ai-regional-esim-modal-overlay-{{ ai_gen_id }}');
      overlay.classList.remove('active');
      document.body.style.overflow = '';
      this.quantity = 1;
      const qtyInput = this.querySelector('#qty-input-{{ ai_gen_id }}');
      if (qtyInput) {
        qtyInput.value = 1;
      }
    }

    formatMoney(cents) {
      const amount = cents / 100;
      return new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: '{{ cart.currency.iso_code }}',
      }).format(amount);
    }
  }

  customElements.define('regional-esim-grid-{{ ai_gen_id }}', RegionalEsimGrid{{ ai_gen_id }});
})();
</script>

