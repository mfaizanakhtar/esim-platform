          "value": "none",
          "label": "None"
        },
        {
          "value": "fade-in",
          "label": "Fade in"
        },
        {
          "value": "slide-up",
          "label": "Slide up"
        },
        {
          "value": "slide-left",
          "label": "Slide left"
        }
      ],
      "default": "fade-in"
    },
    {
      "type": "richtext",
      "id": "subheading_2",
      "label": "Subheading 2",
      "default": "<p>Select your destination and travel dates to see available packages</p>"
    },
    {
      "type": "select",
      "id": "subheading_2_animation",
      "label": "Subheading 2 animation",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "fade-in",
          "label": "Fade in"
        },
        {
          "value": "slide-up",
          "label": "Slide up"
        },
        {
          "value": "slide-left",
          "label": "Slide left"
        }
      ],
      "default": "slide-up"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 12,
