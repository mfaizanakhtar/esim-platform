{% doc %}
  @prompt
    Create a Tabbed product grid block with these exact specifications based on an existing block being duplicated:
    
    HEADER:
    - Heading: "Shop by Region", size: 32px
    - Subheading: "Explore our regional collections", size: 16px
    - Both heading and subheading must have an alignment setting with options: left, center, right (independently controllable)
    - Both heading and subheading must have animation settings with options: none, fade-in, slide-up, slide-in-left — with adjustable animation speed (slow, medium, fast)
    
    LAYOUT:
    - Maximum width: 1200px, section padding: 40px
    - Products per row desktop: up to 12, mobile: up to 6, current default desktop: 8, mobile: 3
    - Grid gap: 12px
    
    TABS (pre-configured):
    - Tab 1: Label "Asia", Collection "asia-1"
    - Tab 2: Label "Europe"
    - Tab 3: Label "Global"
    - Tab 4: Label "Middle East"
    - Tab 5 & 6: empty
    - Tab styles: text #121212, border #cccccc, hover background #f4f4f4, hover border #121212, active background #121212, active text #ffffff, active border #121212
    
    PRODUCT IMAGES:
    - 3:2 landscape aspect ratio, object-fit: cover, zero blank padding or whitespace around image, fills container edge to edge
    
    CARD STYLE:
    - Background: #ffffff, border-radius: 8px, price color: #121212
    
    BUTTON (Add to Cart only, NO View Details button):
    - Pill shape: border-radius: 999px, padding: 8px 24px, max-height: 36px, white-space: nowrap, text on one line
    - Font size: 12px, font weight: 600, text: #ffffff, background: #121212, border: #121212
    - Hover: text #121212, background #ffffff, border #121212
    - Expose as editable: font size, font weight, text color, background color, border color
    
    Block should be homepage-only, fully centered, modern and clean for a futuristic eSIM store
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-tabbed-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-tabbed-grid-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-tabbed-grid-header-{{ ai_gen_id }} {
    margin-bottom: 32px;
  }

  .ai-tabbed-grid-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 8px 0;
    text-align: {{ block.settings.heading_alignment }};
    opacity: 0;
  }

  .ai-tabbed-grid-heading-{{ ai_gen_id }}.ai-animate-{{ ai_gen_id }} {
    animation: ai-heading-{{ ai_gen_id }} {{ block.settings.heading_animation_speed }} forwards;
  }

  .ai-tabbed-grid-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0;
    text-align: {{ block.settings.subheading_alignment }};
    opacity: 0;
  }

  .ai-tabbed-grid-subheading-{{ ai_gen_id }}.ai-animate-{{ ai_gen_id }} {
    animation: ai-subheading-{{ ai_gen_id }} {{ block.settings.subheading_animation_speed }} forwards;
  }

  {% if block.settings.heading_animation == 'fade-in' %}
    @keyframes ai-heading-{{ ai_gen_id }} {
      to {
        opacity: 1;
      }
    }
  {% elsif block.settings.heading_animation == 'slide-up' %}
    @keyframes ai-heading-{{ ai_gen_id }} {
      from {
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  {% elsif block.settings.heading_animation == 'slide-in-left' %}
    @keyframes ai-heading-{{ ai_gen_id }} {
      from {
        transform: translateX(-20px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }
  {% else %}
    @keyframes ai-heading-{{ ai_gen_id }} {
      to {
        opacity: 1;
      }
    }
  {% endif %}

  {% if block.settings.subheading_animation == 'fade-in' %}
    @keyframes ai-subheading-{{ ai_gen_id }} {
      to {
        opacity: 1;
      }
    }
  {% elsif block.settings.subheading_animation == 'slide-up' %}
    @keyframes ai-subheading-{{ ai_gen_id }} {
      from {
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  {% elsif block.settings.subheading_animation == 'slide-in-left' %}
    @keyframes ai-subheading-{{ ai_gen_id }} {
      from {
        transform: translateX(-20px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }
  {% else %}
    @keyframes ai-subheading-{{ ai_gen_id }} {
      to {
        opacity: 1;
      }
    }
  {% endif %}

  .ai-tabbed-grid-tabs-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    margin-bottom: 24px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .ai-tabbed-grid-tab-{{ ai_gen_id }} {
    padding: 12px 24px;
    background: transparent;
    border: 1px solid {{ block.settings.tab_border_color }};
    color: {{ block.settings.tab_text_color }};
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 14px;
    font-weight: 500;
  }

  .ai-tabbed-grid-tab-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.tab_hover_bg }};
    border-color: {{ block.settings.tab_hover_border }};
  }

  .ai-tabbed-grid-tab-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.tab_active_bg }};
    color: {{ block.settings.tab_active_text }};
    border-color: {{ block.settings.tab_active_border }};
  }

  .ai-tabbed-grid-content-{{ ai_gen_id }} {
    display: none;
  }

  .ai-tabbed-grid-content-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-tabbed-grid-products-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-tabbed-grid-products-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_mobile }}, 1fr);
    }
  }

  .ai-tabbed-grid-card-{{ ai_gen_id }} {
    background: {{ block.settings.card_bg }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .ai-tabbed-grid-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 66.67%;
    overflow: hidden;
  }

  .ai-tabbed-grid-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-tabbed-grid-card-info-{{ ai_gen_id }} {
    padding: 12px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-tabbed-grid-product-title-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 500;
    margin: 0 0 8px 0;
    line-height: 1.4;
  }

  .ai-tabbed-grid-product-price-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.price_color }};
    margin: 0 0 12px 0;
    font-weight: 600;
  }

  .ai-tabbed-grid-button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg }};
    color: {{ block.settings.button_text }};
    border: 1px solid {{ block.settings.button_border }};
    border-radius: 999px;
    cursor: pointer;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-align: center;
    text-decoration: none;
    transition: all 0.3s ease;
    white-space: nowrap;
    max-height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .ai-tabbed-grid-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg }};
    color: {{ block.settings.button_hover_text }};
    border-color: {{ block.settings.button_hover_border }};
  }

  .ai-tabbed-grid-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 40px 20px;
    color: #666;
    font-style: italic;
  }
{% endstyle %}

<tabbed-product-grid-{{ ai_gen_id }} class="ai-tabbed-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-tabbed-grid-container-{{ ai_gen_id }}">
    <div class="ai-tabbed-grid-header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-tabbed-grid-heading-{{ ai_gen_id }} {% if block.settings.heading_animation != 'none' %}ai-animate-{{ ai_gen_id }}{% endif %}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="ai-tabbed-grid-subheading-{{ ai_gen_id }} {% if block.settings.subheading_animation != 'none' %}ai-animate-{{ ai_gen_id }}{% endif %}">
          {{ block.settings.subheading }}
        </p>
      {% endif %}
    </div>

    <div class="ai-tabbed-grid-tabs-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% assign tab_label_key = 'tab_' | append: i | append: '_label' %}
        {% assign tab_collection_key = 'tab_' | append: i | append: '_collection' %}
        {% assign tab_label = block.settings[tab_label_key] %}
        {% assign tab_collection = block.settings[tab_collection_key] %}
        
        {% if tab_label != blank %}
          <button 
            class="ai-tabbed-grid-tab-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}" 
            data-tab="{{ i }}"
          >
            {{ tab_label }}
          </button>
        {% endif %}
      {% endfor %}
    </div>

    {% for i in (1..6) %}
      {% assign tab_label_key = 'tab_' | append: i | append: '_label' %}
      {% assign tab_collection_key = 'tab_' | append: i | append: '_collection' %}
      {% assign tab_label = block.settings[tab_label_key] %}
      {% assign tab_collection = block.settings[tab_collection_key] %}
      
      {% if tab_label != blank %}
        <div class="ai-tabbed-grid-content-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}" data-content="{{ i }}">
          {% if tab_collection != blank and tab_collection.products.size > 0 %}
            <div class="ai-tabbed-grid-products-{{ ai_gen_id }}">
              {% for product in tab_collection.products %}
                <div class="ai-tabbed-grid-card-{{ ai_gen_id }}">
                  <div class="ai-tabbed-grid-image-wrapper-{{ ai_gen_id }}">
                    {% if product.featured_image %}
                      <img 
                        src="{{ product.featured_image | image_url: width: 600 }}" 
                        alt="{{ product.featured_image.alt | escape }}"
                        class="ai-tabbed-grid-image-{{ ai_gen_id }}"
                        loading="lazy"
                        width="600"
                        height="400"
                      >
                    {% else %}
                      <div class="ai-tabbed-grid-image-placeholder-{{ ai_gen_id }}">
                        {{ 'product-1' | placeholder_svg_tag }}
                      </div>
                    {% endif %}
                  </div>
                  <div class="ai-tabbed-grid-card-info-{{ ai_gen_id }}">
                    <h3 class="ai-tabbed-grid-product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                    <div class="ai-tabbed-grid-product-price-{{ ai_gen_id }}">{{ product.price | money }}</div>
                    <a href="{{ product.url }}" class="ai-tabbed-grid-button-{{ ai_gen_id }}">
                      Add to Cart
                    </a>
                  </div>
                </div>
              {% endfor %}
            </div>
          {% else %}
            <div class="ai-tabbed-grid-empty-{{ ai_gen_id }}">
              No products found in this collection
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</tabbed-product-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class TabbedProductGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.tabs = this.querySelectorAll('.ai-tabbed-grid-tab-{{ ai_gen_id }}');
        this.contents = this.querySelectorAll('.ai-tabbed-grid-content-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.tabs.forEach((tab) => {
          tab.addEventListener('click', () => {
            const tabId = tab.getAttribute('data-tab');
            
            this.tabs.forEach((t) => t.classList.remove('active'));
            this.contents.forEach((c) => c.classList.remove('active'));
            
            tab.classList.add('active');
            const activeContent = this.querySelector(`[data-content="${tabId}"]`);
            if (activeContent) {
              activeContent.classList.add('active');
            }
          });
        });
      }
    }

    customElements.define('tabbed-product-grid-{{ ai_gen_id }}', TabbedProductGrid{{ ai_gen_id }});
  })();
</script>

