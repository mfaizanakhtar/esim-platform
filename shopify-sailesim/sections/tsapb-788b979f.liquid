{%- liquid
	assign loading = "lazy"
	assign fetchpriority = "auto"
	assign preload = false
	assign grid_logo_sizes = "100vw"
	assign ticker_logo_sizes = "(min-width: 768px) 220px, 160px"
	assign grid_eager_limit = section.settings.logos_per_row_desktop | plus: 0

	if section.settings.logos_list_layout == "grid"
		assign desktop_logo_width = section.settings.section_width | divided_by: section.settings.logos_per_row_desktop
		assign mobile_logo_width = 100 | divided_by: section.settings.logos_per_row_mobile
		assign grid_logo_sizes = "(min-width: 992px) " | append: desktop_logo_width | append: "vw, " | append: mobile_logo_width | append: "vw"
	endif

	if section.index == 1
		assign loading = "eager"
		assign fetchpriority = "high"
		assign preload = true
	endif
-%}

<section
	class="
		Vtls-{{ section.id | handle }} VtlsLogosList
		{% if section.settings.section_width == 100 %}VtlsLogosList--fullWidth{% endif %}
		VtlsLogosList--sectionStyle-{{ section.settings.logos_list_layout }}
	"
>
	<div
		class="
			VtlsLogosListContainer
			VtlsLogosListContainer--backgroundStyle-{{ section.settings.section_background_style }}
			{% if section.settings.section_background_style == "gradient" and section.settings.enable_animation == true %}VtlsLogosListContainer--hasAnimation{% endif %}
			{% if section.settings.heading != blank %}VtlsLogosListContainer--hasHeading{% endif %}
		"
	>
		{%- if section.settings.heading != blank -%}
			<h2
				class="
					VtlsLogosListHeading
					VtlsLogosListHeading--style-{{ section.settings.heading_style }}
				"
			>
				{{ section.settings.heading }}
			</h2>
		{%- endif -%}
		{%- if section.settings.logos_list_layout == "grid" -%}
				<ul class="VtlsLogosListGrid">
					{%- for block in section.blocks -%}
						{%- liquid
							assign logo_image = block.settings.logo_image
							assign block_loading = loading
							assign block_fetchpriority = fetchpriority
							assign block_preload = preload
							if forloop.index > grid_eager_limit
								assign block_loading = "lazy"
								assign block_fetchpriority = "auto"
								assign block_preload = false
							endif
						-%}
						{%- capture logo_css_variables -%}
							--logo-size: {{- block.settings.logo_image_size -}}%;
						{%- if block.settings.block_background_color_enabled -%}
							--section-logos-box-color: {{- block.settings.block_background_color -}};
						{%- endif -%}
					{%- endcapture -%}
					<li
						style="{{- logo_css_variables | strip_newlines | escape -}}"
						class="
							VtlsLogosListBlock
							VtlsLogosListBlock--aspectRatio-{{ section.settings.logos_aspect_ratio }}
							VtlsLogosListBlock--boxStyle-{{ section.settings.logos_box_styles }}
							{% if section.settings.logos_box_shadow %}VtlsLogosListBlock--hasShadow VtlsLogosListBlock--shadowSize-{{ section.settings.shadow_size }}{% endif %}
							VtlsLogosListBlock--hasAnimation
						"
						{{ block.shopify_attributes }}
					>
						{%- if block.settings.logo_link != blank -%}
							<a
								href="{{ block.settings.logo_link }}"
								class="VtlsLogosListBlock__Link"
							>
						{%- endif -%}
						{%- if logo_image != blank -%}
							<div class="VtlsLogosListBlock__Logo">
									{{-
										logo_image
										| image_url: width: logo_image.width
										| image_tag:
											sizes: grid_logo_sizes,
											widths: "64, 96, 128, 160, 220, 320, 480",
											fetchpriority: block_fetchpriority,
											loading: block_loading,
											preload: block_preload
									-}}
								</div>
							{%- else -%}
							<div class="VtlsLogosListBlock__Logo VtlsLogosListBlock__Logo--default">
								<img
									src="data:image/webp;base64,"
									alt="Logo placeholder"
									width="1200"
									height="600"
									sizes="100vw"
								>
							</div>
						{%- endif -%}
						{%- if block.settings.logo_link != blank -%}
							</a>
						{%- endif -%}
					</li>
				{%- endfor -%}
			</ul>
		{% else %}
			<vtls-logos-rotating-ticker
				class="VtlsLogosListTicker"
				data-speed="{{ section.settings.rotating_bar_speed | default: 10 }}"
			>
					{%- for index in (1..10) -%}
						<div class="VtlsLogosListTicker__Wrapper">
							{%- for block in section.blocks -%}
								{%- liquid
									assign logo_image = block.settings.logo_image
									assign block_loading = "lazy"
									assign block_fetchpriority = "auto"
									assign block_preload = false
								-%}
								{%- capture logo_css_variables -%}
									--logo-size: {{- block.settings.logo_image_size -}}%;
								{%- if block.settings.block_background_color_enabled -%}
									--section-logos-box-color: {{- block.settings.block_background_color -}};
								{%- endif -%}
							{%- endcapture -%}
							<li
								style="{{- logo_css_variables | strip_newlines | escape -}}"
								class="
									VtlsLogosListBlock
									VtlsLogosListBlock--tickerEnabled
									VtlsLogosListBlock--aspectRatio-{{ section.settings.logos_aspect_ratio }}
									VtlsLogosListBlock--boxStyle-{{ section.settings.logos_box_styles }}
									{% if section.settings.logos_box_shadow %}VtlsLogosListBlock--hasShadow VtlsLogosListBlock--shadowSize-{{ section.settings.shadow_size }}{% endif %}
									VtlsLogosListBlock--hasAnimation
								"
								{{ block.shopify_attributes }}
							>
								{%- if block.settings.logo_link != blank -%}
									<a
										href="{{ block.settings.logo_link }}"
										class="VtlsLogosListBlock__Link"
									>
								{%- endif -%}
								{%- if logo_image != blank -%}
									<div class="VtlsLogosListBlock__Logo">
											{{-
												logo_image
												| image_url: width: logo_image.width
												| image_tag:
													sizes: ticker_logo_sizes,
													widths: "64, 96, 128, 160, 220, 320, 480",
													fetchpriority: block_fetchpriority,
													loading: block_loading,
													preload: block_preload
											-}}
										</div>
									{%- else -%}
									<div class="VtlsLogosListBlock__Logo VtlsLogosListBlock__Logo--default">
										<img
											src="data:image/webp;base64,"
											alt="Logo placeholder"
											width="1200"
											height="600"
											sizes="100vw"
										>
									</div>
								{%- endif -%}
								{%- if block.settings.logo_link != blank -%}
									</a>
								{%- endif -%}
							</li>
						{%- endfor -%}
					</div>
				{%- endfor -%}
			</vtls-logos-rotating-ticker>
		{%- endif -%}
	</div>
</section>

