<script>
	(function (options) {
		const PARTIAL_VISIBLE_ITEM_SIZE = 0.333;
		const lastRenderedResolution = { width: window.innerWidth, height: window.innerHeight };

		const {
			structure: {
				cardHasBorder,
				columnGap,
				containerId,
				imageAspectRatio,
				showPortionOfLastImage,
				slideBySet,
				visibleItemsDesktop,
