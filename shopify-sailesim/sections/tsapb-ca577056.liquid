{% style %}
:root {
--vtl-neutral-70: #5e5e5e;
--vtl-neutral-01: #fff;
--vtl-blue-100: #0071e9;
--vtl-size-1: 1px;
--vtl-size-2: 2px;
--vtl-size-14: 14px;
--vtl-size-16: 16px;
--vtl-size-20: 20px;
--vtl-size-24: 24px;
--vtl-size-32: 32px;
--vtl-size-40: 40px;
--vtl-size-48: 48px;
--vtl-font-weight-400: 400;
--vtl-font-weight-600: 600;
--vtl-line-height-140: 1.4;
--vtl-text-decoration-none: none;
--vtl-border-width-1: var(--vtl-size-1);
--vtl-color-bg-fill-inverse-on-light: var(--vtl-neutral-01);
--vtl-color-text-disable-on-light: var(--vtl-neutral-70);
--vtl-color-border-focus-on-light: var(--vtl-blue-100);
--vtl-space-2: var(--vtl-size-2);
--vtl-space-16: var(--vtl-size-16);
--vtl-space-20: var(--vtl-size-20);
--vtl-space-24: var(--vtl-size-24);
--vtl-space-32: var(--vtl-size-32);
--vtl-space-40: var(--vtl-size-40);
--vtl-space-48: var(--vtl-size-48);
--vtl-font-size-14: var(--vtl-size-14);
}


{% endstyle %}

<!-- --UUID-ca577056-- -->

{%- liquid
	assign loading = "lazy"
	assign fetchpriority = "auto"
	assign preload = false

	if section.index == 1
		assign loading = "eager"
		assign fetchpriority = "high"
		assign preload = true
	endif
-%}

<section class="Vtls-{{ section.id | handle }} VtlsCollListShape"{% if section.settings.heading != blank %} aria-labelledby="section-heading-{{ section.id | handle }}"{% else %} aria-label="Collections section"{% endif %}>
	<div
		class="
			VtlsCollListShapeContainer VtlsCarouselContainer
			VtlsCarouselContainer--style-{{ section.settings.heading_style }}
			{% if section.settings.section_width == 100 %}VtlsCollListShapeContainer--fullWidth{% endif %}
		"
	>
		{%- if section.settings.heading != blank -%}
			<h2
				id="section-heading-{{ section.id | handle }}"
				class="
					VtlsCollListHeading
					{% if section.settings.layout_desktop == "grid" %}VtlsCollListHeading--desktopHidden{% endif %}
					{% if section.settings.layout_mobile == "grid" %}VtlsCollListHeading--mobileHidden{% endif %}
					 VtlsCollListHeading--alignment-{{ section.settings.heading_alignment }}
					 VtlsCollListHeading--style-{{ section.settings.heading_style }}
				"
			>
				{{ section.settings.heading }}
			</h2>
		{%- endif -%}

		<div
			class="
				VtlsCarousel
				{% if section.settings.layout_desktop == "grid" %}VtlsCarouselListGrid--desktop{% endif %}
				{% if section.settings.layout_mobile == "grid" %}VtlsCarouselListGrid--mobile{% endif %}
			"
			data-section-width="{{ section.settings.section_width }}"
			aria-label="Collections carousel"
			aria-live="polite"
		>
			<div class="VtlsCarousel__Content">
				<ul class="VtlsCarouselList">
					{%- for block in section.blocks -%}
						{%- liquid
							assign collection = block.settings.collection
							assign collection_image = block.settings.collection.featured_image
							assign collection_url = block.settings.collection.url
							assign desktop_image = block.settings.image_desktop
							assign mobile_image = block.settings.image_mobile
							assign heading = block.settings.collection.title

							if mobile_image == blank and desktop_image != blank
								assign mobile_image = block.settings.image_desktop
							endif
							if mobile_image == blank
								assign mobile_image = block.settings.collection.featured_image
							endif
							if desktop_image != blank
								assign collection_image = desktop_image
							endif
							if block.settings.heading != blank
								assign heading = block.settings.heading
							endif

							assign desktop_width = 100 | divided_by: section.settings.collections_per_row_desktop
							assign mobile_width = 100 | divided_by: section.settings.collections_per_row_mobile

							assign desktop_sizes = "(min-width: 992px) " | append: desktop_width | append: "vw, 0"
							assign mobile_sizes = "(min-width: 992px) 0, " | append: mobile_width | append: "vw"
						-%}
						<li
							class="VtlsCollListBlock"
							{{ block.shopify_attributes }}
							{% if forloop.first and section.settings.heading_alignment == "left" %}
								data-title-left="{{ section.settings.heading | escape }}"
							{% endif %}
							{%- if forloop.index == section.settings.collections_per_row_desktop
								and section.settings.heading_alignment == "right"
							-%}
								data-title-right="{{ section.settings.heading | escape }}"
							{%- endif -%}
						>
							{%- if forloop.first and section.settings.heading_alignment == "left" %}
								<h2 class="VtlsHeadingLeft">{{ section.settings.heading | escape }}</h2>
							{%- endif -%}

							{%- assign collections_per_row_mobile = section.settings.collections_per_row_mobile
								| plus: 0
							-%}

							{%- if forloop.index == collections_per_row_mobile
								and section.settings.heading_alignment == "right"
							-%}
								<h2 class="VtlsHeadingRight VtlsHeadingRight--mobile">
									{{ section.settings.heading | escape }}
								</h2>
							{%- endif -%}

							{%- if forloop.index == section.settings.collections_per_row_desktop
								and section.settings.heading_alignment == "right"
							-%}
								<h2 class="VtlsHeadingRight VtlsHeadingRight--desktop">
									{{ section.settings.heading | escape }}
								</h2>
							{%- endif -%}

						<article class="VtlsCollListBlock__Wrapper" aria-label="View {{ heading | default: 'collection' }} products">
							<a
								href="{{- collection_url -}}"
								class="
									VtlsCollListBlock__Media
									{% if collection == blank %}
												VtlsCollListBlock__Media--inactiveLink
									{% endif %}
									{% if section.settings.images_border_color != blank %}VtlsCollListBlock__Media--hasBorder{% endif %}
								"
								aria-label="View {{ heading | default: 'collection' }} products"
							>
									{%- if collection_image -%}
										{{-
											collection_image
											| image_url: width: collection_image.width
											| image_tag:
												sizes: desktop_sizes,
												widths: "1, 400, 600, 800, 1200, 1600, 1800, 2400, 2800, 3200",
												fetchpriority: fetchpriority,
												loading: loading,
												preload: preload,
												class: "VtlsCollListBlock__Image VtlsCollListBlock__Image--desktop",
											alt: heading | default: "Collection image"
										-}}
									{%- else -%}
										<img
											src="data:image/webp;base64,"
											alt="{{ heading | default: 'Collection image' | escape }}"
											width="520"
											height="520"
											sizes="100vw"
											class="VtlsCollListBlock__Image VtlsCollListBlock__Image--desktop"
										>
									{%- endif -%}
									{%- if mobile_image -%}
										{{-
											mobile_image
											| image_url: width: mobile_image.width
											| image_tag:
												sizes: mobile_sizes,
												widths: "1, 400, 600, 800, 1200, 1600, 1800",
												fetchpriority: fetchpriority,
												loading: loading,
												preload: preload,
												class: "VtlsCollListBlock__Image VtlsCollListBlock__Image--mobile",
											alt: heading | default: "Collection image"
										-}}
									{%- else -%}
										<img
											src="data:image/webp;base64,"
											alt="{{ heading | default: 'Collection image' | escape }}"
											width="520"
											height="520"
											sizes="100vw"
											class="VtlsCollListBlock__Image VtlsCollListBlock__Image--mobile"
										>
									{%- endif -%}
								</a>
							<div class="VtlsCollListBlock__Content">
								{%- if heading -%}
									<h3 class="VtlsCollListBlock__Heading">
										<a href="{{- block.settings.collection.url -}}">
											{{- heading | escape -}}
										</a>
									</h3>
								{%- else -%}
									<h3 class="VtlsCollListBlock__Heading"> Collection title </h3>
								{%- endif -%}
							</div>
						</article>
						</li>
					{%- endfor -%}
				</ul>
				<nav class="VtlsCarousel__Navigation" aria-label="Carousel navigation">
					<div class="VtlsNavigationButtons" role="group" aria-label="Navigation controls">
						{%- liquid
							assign is_rtl = false
							if request.locale.iso_code contains 'ar' or request.locale.iso_code contains 'he' or request.locale.iso_code contains 'fa'
								assign is_rtl = true
							endif
						-%}
						{%- if is_rtl -%}
							<button 
								class="VtlsNavigationButtons__Button right-chevron"
								aria-label="Previous collections"
								type="button"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="24"
									height="24"
									viewBox="0 0 24 24"
									fill="none"
									aria-hidden="true"
								>
									<path d="M9 6L15 12L9 18" stroke="#222" stroke-linecap="round"></path>
								</svg>
							</button>
							<button 
								class="VtlsNavigationButtons__Button VtlsNavigationButtons__Button--disabled left-chevron"
								aria-label="Next collections"
								type="button"
								disabled
								aria-disabled="true"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="24"
									height="24"
									viewBox="0 0 24 24"
									fill="none"
									aria-hidden="true"
								>
									<path d="M14 18L8 12L14 6" stroke="#222" stroke-linecap="round"></path>
								</svg>
							</button>
						{%- else -%}
							<button 
								class="VtlsNavigationButtons__Button VtlsNavigationButtons__Button--disabled left-chevron"
								aria-label="Previous collections"
								type="button"
								disabled
								aria-disabled="true"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="24"
									height="24"
									viewBox="0 0 24 24"
									fill="none"
									aria-hidden="true"
								>
									<path d="M14 18L8 12L14 6" stroke="#222" stroke-linecap="round"></path>
								</svg>
							</button>
							<button 
								class="VtlsNavigationButtons__Button right-chevron"
								aria-label="Next collections"
								type="button"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="24"
									height="24"
									viewBox="0 0 24 24"
									fill="none"
									aria-hidden="true"
								>
									<path d="M9 6L15 12L9 18" stroke="#222" stroke-linecap="round"></path>
								</svg>
							</button>
						{%- endif -%}
					</div>
				</nav>
			</div>
		</div>
	</div>
</section>

