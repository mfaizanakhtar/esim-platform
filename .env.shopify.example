# Shopify CLI environment variables
# Copy this file to .env.shopify and fill in your values.
# .env.shopify is gitignored — never commit it.

# Your Shopify store URL (e.g. my-store.myshopify.com)
SHOPIFY_FLAG_STORE=your-store.myshopify.com

# The numeric theme ID to push/pull (find it in Online Store > Themes > ... > Edit code — the ID is in the URL)
SHOPIFY_FLAG_THEME_ID=123456789

# Shopify CLI token for CI / non-interactive auth.
# Generate one at: Partners Dashboard > Apps > your-app > API credentials
# Or use a private-app Admin API token with write_themes scope.
SHOPIFY_CLI_THEME_TOKEN=shptka_xxxxxxxxxxxxxxxxxxxx
