# Shopify theme CLI — local development
# Copy to .env.shopify and fill in your values.
# .env.shopify is gitignored — never commit it.
#
# NOTE: SHOPIFY_CLIENT_ID, SHOPIFY_CLIENT_SECRET, and SHOPIFY_SHOP_DOMAIN
# are already defined in fulfillment-engine/.env — these are the same values.
# The CI workflow reuses those secrets automatically; you only need this file
# for local `npm run theme:pull / theme:push / theme:dev` commands.

# Your Shopify store URL (same as fulfillment-engine SHOPIFY_SHOP_DOMAIN)
SHOPIFY_FLAG_STORE=your-store.myshopify.com

# The numeric theme ID to push/pull
# Find it: Shopify Admin → Online Store → Themes → ⋯ → Edit code → look at the URL
SHOPIFY_FLAG_THEME_ID=123456789

# Access token with write_themes scope.
# Generate locally by running the fulfillment-engine client credentials flow,
# or get a one-time token with: cd fulfillment-engine && npx ts-node scripts/get-theme-token.ts
SHOPIFY_CLI_THEME_TOKEN=
