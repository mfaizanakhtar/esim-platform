generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model EsimDelivery {
  id                String            @id @default(cuid())
  shop              String
  orderId           String
  orderName         String
  lineItemId        String
  variantId         String
  customerEmail     String?
  vendorReferenceId String?
  provider          String?   // 'firoam' | 'tgt' — set at provision time
  iccidHash         String?   // HMAC-SHA256(iccid, ENCRYPTION_KEY) — indexed for fast lookup
  payloadEncrypted  String?
  accessToken       String?   @unique // UUID issued after delivery; used by Shopify UI extension
  topupIccid        String?   // if set: this delivery tops up an existing eSIM with this ICCID
  sku               String?   // Shopify SKU from line item — cached for mapping lookup
  status            String            @default("pending")
  lastError         String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  attempts          DeliveryAttempt[]
  esimOrders        EsimOrder[]

  @@index([iccidHash])
}

model DeliveryAttempt {
  id         String       @id @default(cuid())
  deliveryId String
  channel    String
  result     String?
  createdAt  DateTime     @default(now())
  delivery   EsimDelivery @relation(fields: [deliveryId], references: [id])
}

model EsimOrder {
  id                String        @id @default(cuid())
  deliveryId        String?
  vendorReferenceId String        @unique
  payloadJson       Json?
  payloadEncrypted  String?
  status            String        @default("created")
  lastError         String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  delivery          EsimDelivery? @relation(fields: [deliveryId], references: [id])
}

model ProviderSkuMapping {
  id                String              @id @default(cuid())
  shopifySku        String              // no longer @unique — multiple providers per SKU
  provider          String              // 'firoam', 'tgt', etc.
  providerSku       String              // Provider's package/plan code — format is provider-specific (e.g. "skuId:apiCode:priceId" for FiRoam)
  providerConfig    Json?               // Vendor-specific structured extras (nullable, non-breaking for existing rows)
  name              String?             // Friendly name
  region            String?             // e.g. 'EU', 'Global', 'Asia'
  dataAmount        String?             // e.g. '5GB', '10GB'
  validity          String?             // e.g. '30 days', '7 days'
  isActive          Boolean             @default(true)
  priority          Int                 @default(1)     // 1 = highest priority; lower number = tried first
  priorityLocked    Boolean             @default(false) // if true, smart pricing won't reorder this row
  mappingLocked     Boolean             @default(false) // if true, UI blocks edits/deletion without explicit unlock
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  packageType       String?             @default("fixed") // 'fixed' or 'daypass'
  daysCount         Int?                // Number of days (required for daypass packages)
  providerCatalogId String?             // FK to ProviderSkuCatalog — new mappings link here; legacy rows keep providerSku
  catalogEntry      ProviderSkuCatalog? @relation(fields: [providerCatalogId], references: [id], onDelete: SetNull)

  @@unique([shopifySku, provider])      // one entry per (shopify sku + provider)
  @@index([shopifySku, priority])       // fast priority-ordered lookup during provisioning
  @@index([provider])
  @@index([isActive])
  @@index([packageType])
  @@index([providerCatalogId])
}

model ProviderSkuCatalog {
  id            String               @id @default(cuid())
  provider      String
  productCode   String
  skuId         String               @default("")  // FiRoam: sku.skuid as string; TGT/others: ""
  skuName       String?                            // FiRoam: sku.display (human name); TGT: null
  productName   String
  productType   String?
  region        String?
  countryCodes  Json?
  dataAmount    String?
  validity      String?
  netPrice      Decimal?             @db.Decimal(28, 2)
  currency      String?
  cardType      String?
  activeType    String?
  rawPayload    Json?
  parsedJson    Json?                // { regionCodes: string[], dataMb: number, validityDays: number }
  isActive      Boolean              @default(true)
  lastSyncedAt  DateTime             @default(now())
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  skuMappings   ProviderSkuMapping[]
  // embedding vector(1536) -- pgvector column, managed via raw migration (not a Prisma field)

  @@unique([provider, skuId, productCode])
  @@index([provider])
  @@index([skuId])
  @@index([isActive])
}

model ShopifyVariant {
  variantId    String   @unique           // Shopify GID: gid://shopify/ProductVariant/123
  sku          String
  productTitle String?
  variantTitle String?
  price        Decimal? @db.Decimal(28, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt        // updated on every sync

  @@index([sku])
}

model AiMapJob {
  id               String    @id @default(cuid())
  status           String    @default("running") // running | done | error | interrupted
  provider         String?
  unmappedOnly     Boolean   @default(true)
  totalBatches     Int?
  completedBatches Int       @default(0)
  foundSoFar       Int       @default(0)
  draftsJson          Json      @default("[]")
  unmatchedSkusJson   Json      @default("[]")
  warning          String?
  error            String?
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  @@map("AiMapJob")
}

model ShopifyProductTemplate {
  id               String                         @id @default(cuid())
  countryCode      String                         @unique
  title            String
  handle           String                         @unique
  descriptionHtml  String                         @db.Text
  status           String                         @default("DRAFT")
  productType      String                         @default("eSIM")
  vendor           String                         @default("SAILeSIM")
  tags             Json                           @default("[]")
  imageUrl         String?
  seoTitle         String?
  seoDescription   String?                        @db.Text
  shopifyProductId String?                        @unique
  shopifyPushedAt  DateTime?
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt
  variants         ShopifyProductTemplateVariant[]

  @@index([status])
}

model ShopifyProductTemplateVariant {
  id              String                 @id @default(cuid())
  templateId      String
  sku             String
  price           Decimal                @db.Decimal(10, 2)
  planType        String                 // "Day-Pass" | "Total Data"
  validity        String                 // "1-Day", "7-Days", etc.
  volume          String                 // "1 GB", "10GB", etc.
  sortOrder       Int                    @default(0)
  priceLocked     Boolean                @default(false)
  providerCost    Decimal?               @db.Decimal(10, 2)
  costFloor       Decimal?               @db.Decimal(10, 2)
  competitorPrice Decimal?               @db.Decimal(10, 2)
  competitorBrand String?
  proposedPrice   Decimal?               @db.Decimal(10, 2)
  priceSource     String?                // "cost_floor" | "competitor" | "manual" | "default"
  marketPosition  String?                // "competitive" | "above_market" | "no_data"
  lastPricedAt    DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  template        ShopifyProductTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, sku])
  @@index([templateId])
  @@index([sku])
}

model CompetitorPrice {
  id           String   @id @default(cuid())
  countryCode  String
  countrySlug  String
  brand        String
  planName     String?
  price        Decimal  @db.Decimal(10, 2)
  dataMb       Int
  validityDays Int
  coverageType String?
  promoCode    String?
  originalPrice Decimal? @db.Decimal(10, 2)
  rawPayload   Json?
  scrapedAt    DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([countryCode, brand, dataMb, validityDays])
  @@index([countryCode, dataMb, validityDays])
  @@index([scrapedAt])
}

model PricingRun {
  id             String    @id @default(cuid())
  type           String    // "cost_floor" | "competitor_scrape" | "smart_pricing" | "shopify_push"
  status         String    @default("running")
  scope          String?
  params         Json?
  totalProcessed Int       @default(0)
  totalUpdated   Int       @default(0)
  totalSkipped   Int       @default(0)
  totalErrors    Int       @default(0)
  error          String?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?
}
