# Copy to .env and fill values
DATABASE_URL=postgresql://user:pass@localhost:5432/esim
PORT=3000

# Shopify Dev Dashboard App (client credentials grant)
# Create app at https://dev.shopify.com/dashboard/
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_CLIENT_ID=  # From Dev Dashboard Settings page
SHOPIFY_CLIENT_SECRET=  # From Dev Dashboard Settings page
SHOPIFY_WEBHOOK_SECRET=  # From Dev Dashboard API configuration
SHOPIFY_CUSTOM_DOMAIN=   # Optional: your storefront domain (e.g. fluxyfi.com) — used in usage-tracking URLs

# FiRoam vendor API
# For production orders:
FIROAM_BASE_URL=https://bpm.roamwifi.hk
FIROAM_PHONE=
FIROAM_PASSWORD=
FIROAM_SIGN_KEY=   # Provided by FiRoam (32-char signing key)

# FiRoam test credentials (optional - used by live integration tests when FIROAM_INTEGRATION=true)
# Note: FiRoam doesn't have a sandbox - integration tests run against production with test account
FIROAM_INTEGRATION=false
FIROAM_E2E_ORDERS=false
FIROAM_TEST_PHONE=
FIROAM_TEST_PASSWORD=

# Admin API (protects /admin/* routes)
ADMIN_API_KEY=            # Any strong secret string; sent as x-admin-key header by the dashboard

ENCRYPTION_KEY=replace-with-32-byte-hex-or-base64

# Resend (transactional email delivery — https://resend.com)
EMAIL_FROM=orders@fluxyfi.com  # Sender address (used in From header; must be a verified Resend domain)
RESEND_API_KEY=           # Get from Resend dashboard → API Keys
EMAIL_BCC=                # Optional: BCC all eSIM delivery emails to this address (e.g. for logging)

# TGT Technology vendor API
# Credentials are provided by TGT after signing up through their sales team.
# Sandbox: https://enterpriseapisandbox.tugegroup.com:8070/openapi (use for testing, no real charges)
# Production: https://enterpriseapi.tugegroup.com:8070/openapi
TGT_ENABLED=false
TGT_BASE_URL=https://enterpriseapisandbox.tugegroup.com:8070/openapi
TGT_ACCOUNT_ID=             # Provided by TGT (accountId)
TGT_SECRET=                 # Provided by TGT (secret / API key)

# Callback secret for verifying incoming TGT webhooks.
# If blank, falls back to TGT_SECRET above.
TGT_CALLBACK_SECRET=

# How to deliver eSIMs from TGT orders:
#   hybrid  - poll first, fall back to callback (recommended, default)
#   polling - poll only (good for sandbox where callbacks aren't available)
#   callback - wait for TGT webhook only (requires public callback URL in TGT portal)
TGT_FULFILLMENT_MODE=hybrid
TGT_POLL_INTERVAL_SECONDS=15   # seconds between poll attempts
TGT_POLL_MAX_ATTEMPTS=8        # attempts before switching to awaiting_callback (hybrid) or failing (polling)

# TGT integration test flags (used by src/tests/tgt.integration.test.ts)
# TGT_INTEGRATION=true          → enables the "authenticate + list products" test
# TGT_E2E_ORDERS=true           → also places a real order and generates QR + HTML report in test-output/
# TGT_TEST_EMAIL=you@example.com → (optional) TGT will email the provisioned QR code to this address
TGT_INTEGRATION=false
TGT_E2E_ORDERS=false
TGT_TEST_EMAIL=
